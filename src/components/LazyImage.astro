---
export interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
}

const { src, alt, width, height, class: className } = Astro.props;
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  class={`lazy-image ${className || ''}`}
  loading="lazy"
  decoding="async"
  onload="this.classList.add('loaded')"
/>

<style>
  .lazy-image {
    opacity: 0;
    transition: opacity 0.3s ease;
    max-width: 100%;
    height: auto;
  }

  .lazy-image.loaded {
    opacity: 1;
  }
</style>
