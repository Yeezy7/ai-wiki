---
import Comments from './Comments.astro';
---

<div class="comments-wrapper">
  <h2>评论</h2>
  <Comments />
</div>

<style>
  .comments-wrapper {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .comments-wrapper h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--sl-color-white);
  }
</style>
