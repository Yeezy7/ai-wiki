---
---

<div class="ai-chat-container">
  <div class="ai-chat-header">
    <h3>AI 问答助手</h3>
    <button id="toggle-chat" class="toggle-btn" aria-label="展开/收起">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>
  </div>

  <div class="ai-chat-body" id="chat-body">
    <div class="ai-chat-messages" id="chat-messages">
      <div class="message ai-message">
        <div class="message-content">
          你好！我是 AI 问答助手。你可以问我关于当前页面内容的问题。
        </div>
      </div>
    </div>

    <div class="ai-chat-input">
      <textarea
        id="chat-input"
        placeholder="输入你的问题..."
        rows="3"
      ></textarea>
      <button id="send-btn" class="send-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
        发送
      </button>
    </div>

    <div class="ai-chat-settings">
      <details>
        <summary>API 设置</summary>
        <div class="settings-form">
          <div class="form-group">
            <label for="api-url">API 地址</label>
            <input
              type="text"
              id="api-url"
              placeholder="https://api.openai.com/v1/chat/completions"
              value="https://api.openai.com/v1/chat/completions"
            />
          </div>
          <div class="form-group">
            <label for="api-key">API Key</label>
            <input
              type="password"
              id="api-key"
              placeholder="sk-..."
            />
          </div>
          <div class="form-group">
            <label for="api-model">模型</label>
            <input
              type="text"
              id="api-model"
              placeholder="gpt-3.5-turbo"
              value="gpt-3.5-turbo"
            />
          </div>
          <button id="save-settings" class="save-btn">保存设置</button>
        </div>
      </details>
    </div>
  </div>
</div>

<script>
  class AIChat {
    constructor() {
      this.messages = [];
      this.isLoading = false;
      this.settings = this.loadSettings();
      this.init();
    }

    loadSettings() {
      const saved = localStorage.getItem('ai-chat-settings');
      return saved ? JSON.parse(saved) : {
        apiUrl: 'https://api.openai.com/v1/chat/completions',
        apiKey: '',
        model: 'gpt-3.5-turbo'
      };
    }

    saveSettings() {
      localStorage.setItem('ai-chat-settings', JSON.stringify(this.settings));
    }

    init() {
      // 切换聊天窗口
      document.getElementById('toggle-chat')?.addEventListener('click', () => {
        const body = document.getElementById('chat-body');
        const btn = document.getElementById('toggle-chat');
        body?.classList.toggle('collapsed');
        btn?.classList.toggle('collapsed');
      });

      // 发送消息
      document.getElementById('send-btn')?.addEventListener('click', () => this.sendMessage());
      document.getElementById('chat-input')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          this.sendMessage();
        }
      });

      // 保存设置
      document.getElementById('save-settings')?.addEventListener('click', () => {
        this.settings.apiUrl = document.getElementById('api-url')?.value || '';
        this.settings.apiKey = document.getElementById('api-key')?.value || '';
        this.settings.model = document.getElementById('api-model')?.value || '';
        this.saveSettings();
        alert('设置已保存！');
      });

      // 加载已保存的设置
      this.loadSettingsToForm();
    }

    loadSettingsToForm() {
      const apiUrlInput = document.getElementById('api-url');
      const apiKeyInput = document.getElementById('api-key');
      const apiModelInput = document.getElementById('api-model');

      if (apiUrlInput) apiUrlInput.value = this.settings.apiUrl || '';
      if (apiKeyInput) apiKeyInput.value = this.settings.apiKey || '';
      if (apiModelInput) apiModelInput.value = this.settings.model || '';
    }

    getPageContext() {
      // 获取当前页面的主要内容作为上下文
      const mainContent = document.querySelector('.sl-markdown-content');
      if (mainContent) {
        return mainContent.textContent?.substring(0, 2000) || '';
      }
      return '';
    }

    async sendMessage() {
      const input = document.getElementById('chat-input');
      const message = input?.value?.trim();

      if (!message || this.isLoading) return;

      // 清空输入
      input.value = '';

      // 添加用户消息
      this.addMessage('user', message);

      // 检查 API 设置
      if (!this.settings.apiKey) {
        this.addMessage('ai', '请先在设置中配置 API Key。');
        return;
      }

      // 显示加载状态
      this.isLoading = true;
      this.updateSendButton();

      try {
        const pageContext = this.getPageContext();
        const systemPrompt = `你是一个 AI 知识库助手。当前页面的内容是：\n\n${pageContext}\n\n请根据用户的问题和页面内容进行回答。`;

        const response = await fetch(this.settings.apiUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${this.settings.apiKey}`
          },
          body: JSON.stringify({
            model: this.settings.model,
            messages: [
              { role: 'system', content: systemPrompt },
              ...this.messages.map(m => ({
                role: m.role === 'user' ? 'user' : 'assistant',
                content: m.content
              }))
            ],
            temperature: 0.7,
            max_tokens: 1000
          })
        });

        if (!response.ok) {
          throw new Error(`API 请求失败: ${response.status}`);
        }

        const data = await response.json();
        const aiMessage = data.choices?.[0]?.message?.content || '抱歉，无法获取回答。';
        this.addMessage('ai', aiMessage);
      } catch (error) {
        console.error('AI Chat Error:', error);
        this.addMessage('ai', `错误：${error.message}`);
      } finally {
        this.isLoading = false;
        this.updateSendButton();
      }
    }

    addMessage(role, content) {
      const messagesContainer = document.getElementById('chat-messages');
      if (!messagesContainer) return;

      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${role === 'user' ? 'user-message' : 'ai-message'}`;
      messageDiv.innerHTML = `
        <div class="message-content">${this.escapeHtml(content)}</div>
      `;

      messagesContainer.appendChild(messageDiv);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;

      this.messages.push({ role, content });
    }

    escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    updateSendButton() {
      const btn = document.getElementById('send-btn');
      if (btn) {
        btn.disabled = this.isLoading;
        btn.textContent = this.isLoading ? '发送中...' : '发送';
      }
    }
  }

  // 初始化
  document.addEventListener('DOMContentLoaded', () => {
    new AIChat();
  });
</script>

<style>
  .ai-chat-container {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 350px;
    max-height: 500px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    z-index: 1000;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ai-chat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: var(--sl-color-accent);
    color: white;
  }

  .ai-chat-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .toggle-btn {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .toggle-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .toggle-btn.collapsed svg {
    transform: rotate(180deg);
  }

  .ai-chat-body {
    display: flex;
    flex-direction: column;
    max-height: 450px;
    transition: max-height 0.3s ease;
  }

  .ai-chat-body.collapsed {
    max-height: 0;
    overflow: hidden;
  }

  .ai-chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    min-height: 200px;
    max-height: 300px;
  }

  .message {
    margin-bottom: 12px;
  }

  .message-content {
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.9rem;
    line-height: 1.5;
    word-wrap: break-word;
  }

  .user-message .message-content {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-white);
    margin-left: 40px;
    border-bottom-right-radius: 4px;
  }

  .ai-message .message-content {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    margin-right: 40px;
    border-bottom-left-radius: 4px;
  }

  .ai-chat-input {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .ai-chat-input textarea {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
    font-size: 0.9rem;
    resize: none;
    font-family: inherit;
  }

  .ai-chat-input textarea:focus {
    outline: none;
    border-color: var(--sl-color-accent);
  }

  .send-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: var(--sl-color-accent);
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .send-btn:hover:not(:disabled) {
    background: var(--sl-color-accent-high);
  }

  .send-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .ai-chat-settings {
    padding: 12px 16px;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .ai-chat-settings details summary {
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }

  .settings-form {
    margin-top: 12px;
  }

  .form-group {
    margin-bottom: 12px;
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    margin-bottom: 4px;
    color: var(--sl-color-gray-2);
  }

  .form-group input {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 6px;
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
    font-size: 0.85rem;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--sl-color-accent);
  }

  .save-btn {
    width: 100%;
    padding: 8px;
    background: var(--sl-color-accent);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
  }

  .save-btn:hover {
    background: var(--sl-color-accent-high);
  }

  @media (max-width: 480px) {
    .ai-chat-container {
      width: calc(100% - 40px);
      bottom: 10px;
      right: 20px;
    }
  }
</style>
